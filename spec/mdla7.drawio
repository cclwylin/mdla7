                <mxCell id="lgd2_l1" value="&lt;span style=&quot;background:#e6f3e0;padding:2px 8px;border:1px solid #82b366&quot;&gt;&amp;nbsp;Cluster 0–11&amp;nbsp;&lt;/span&gt;&amp;nbsp;&amp;nbsp;INT-only (1024 INT8 MAC each, no FP datapath)&amp;nbsp;&amp;nbsp;|&amp;nbsp;&amp;nbsp;&lt;span style=&quot;background:#b3d9ff;padding:2px 8px;border:1px solid #3070b0&quot;&gt;&amp;nbsp;Cluster 12–15&amp;nbsp;&lt;/span&gt;&amp;nbsp;&amp;nbsp;INT + FP (256 FP MAC each)" style="text;html=1;fontSize=11;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;" parent="1" vertex="1">
                    <mxGeometry x="60" y="1085" width="1540" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="lgd2_l2" value="Gray dashed = 1T INT32 chain (cluster → its dedicated Requant lane).&amp;nbsp;&amp;nbsp;Blue thick = AXI 128b bus.&amp;nbsp;&amp;nbsp;Each Requant lane has independent (scale, shift, zero-point) → per-output-channel quantization." style="text;html=1;fontSize=11;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;" parent="1" vertex="1">
                    <mxGeometry x="60" y="1115" width="1540" height="22" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
    <diagram name="L1Mesh-4x4-NoC" id="mdla7-l1mesh-4x4-noc">
        <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
