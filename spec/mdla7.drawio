                    <mxGeometry x="80" y="210" width="260" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="l1n_wgt" value="CONV WGT_R&lt;br/&gt;32 x 128b direct ingress" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#0050ef;fontSize=14;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="80" y="330" width="260" height="70" as="geometry"/>
                </mxCell>
                <mxCell id="l1n_mgr" value="L1_Manager&lt;br/&gt;non-CONV R/W ingress&lt;br/&gt;16R + 16W" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="80" y="455" width="260" height="85" as="geometry"/>
                </mxCell>
                <mxCell id="l1n_meshbox" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fffafa;strokeColor=#b85450;strokeWidth=2;" parent="1" vertex="1">
                    <mxGeometry x="500" y="190" width="760" height="720" as="geometry"/>
                </mxCell>
                <mxCell id="l1n_meshtitle" value="Four 4x4 NoC planes sharing one 16-bank SRAM array" style="text;html=1;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=#ffffff;" parent="1" vertex="1">
                    <mxGeometry x="600" y="200" width="560" height="30" as="geometry"/>
                </mxCell>
