                <mxCell id="title2" value="CONV Engine Internal — 16 cluster + per-cluster Requant chain" style="text;html=1;fontSize=22;fontStyle=1;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;" parent="1" vertex="1">
