                <mxCell id="legend_title" value="Legend / Conventions" style="text;html=1;fontSize=16;fontStyle=1;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;" parent="1" vertex="1">
                    <mxGeometry x="60" y="1290" width="400" height="26" as="geometry"/>
                </mxCell>
                <mxCell id="legend_axi_line" style="endArrow=classic;html=1;rounded=0;strokeColor=#0050ef;fillColor=#0050ef;strokeWidth=2;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="80" y="1340" as="sourcePoint"/>
                        <mxPoint x="200" y="1340" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="legend_axi_text" value="&lt;b&gt;Blue (thick)&lt;/b&gt; — AXI 128-bit bus.&amp;nbsp;Number on edge = parallel bus count (provisional, may be revised). Total BW per link = N × 128 bits/cycle." style="text;html=1;fontSize=12;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;" parent="1" vertex="1">
                    <mxGeometry x="220" y="1326" width="2020" height="28" as="geometry"/>
                </mxCell>
                <mxCell id="legend_1t_line" style="endArrow=classic;html=1;rounded=0;strokeColor=#888888;strokeWidth=1.5;dashed=1;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="80" y="1380" as="sourcePoint"/>
                        <mxPoint x="200" y="1380" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="legend_1t_text" value="&lt;b&gt;Gray dashed (thin)&lt;/b&gt; — 1T fire-and-forget payload. Whole config / data packet latched in a single cycle. No AXI handshake. Used for Host→Cmd descriptor, Cmd→Engine config (W), and (in v0) UDMA↔DRAM." style="text;html=1;fontSize=12;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;" parent="1" vertex="1">
                    <mxGeometry x="220" y="1366" width="2020" height="28" as="geometry"/>
                </mxCell>
                <mxCell id="legend_notes" value="&lt;b&gt;Notes&lt;/b&gt;&amp;nbsp;&amp;nbsp;• CONV ACT/WGT AXI_R connects directly to L1Mesh and bypasses L1_Manager; arrow direction = data-flow direction (R = up to engine, W = down to L1_Manager).&amp;nbsp;&amp;nbsp;• CONV has no AXI_W; its INT32 partial-sum outputs chain to Requant via a dedicated path (TBD — see spec.md §6.2).&lt;br/&gt;• L1_Manager arbitrates non-CONV engines / UDMA and connects to L1Mesh through 16 R + 16 W ports (TBD: truly dual-port or single port routed both ways).&amp;nbsp;&amp;nbsp;• CONV cycle model is dtype-aware via bit-mult invariant: cycle = ⌈ MAC_total × bit_a × bit_b / 1,048,576 ⌉ + tile fill. See spec.md §3A.2 / §5.3.&lt;br/&gt;• &lt;b&gt;TNPS (new in v0.2)&lt;/b&gt;: pure on-chip transpose engine, L1↔L1 only (8 R + 8 W); decoupled from UDMA&#39;s STRIDED_SCATTER so attention reshapes don&#39;t compete with main load/store traffic. See spec.md §3A.7b." style="text;html=1;fontSize=12;align=left;verticalAlign=top;strokeColor=none;fillColor=none;" parent="1" vertex="1">
                    <mxGeometry x="60" y="1410" width="2200" height="100" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
    <diagram name="CONV-Requant-Internal" id="mdla7-conv-internal">
        <mxGraphModel dx="857" dy="913" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
