    <diagram name="MDLA7" id="mdla7-v1">
        <mxGraphModel dx="836" dy="907" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2339" pageHeight="1654" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
