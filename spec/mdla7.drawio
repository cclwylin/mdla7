    <diagram name="L1Mesh-Arbitration" id="mdla7-l1mesh-arbitration">
        <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="arb_title" value="L1Mesh Request Arbitration" style="text;html=1;fontSize=24;fontStyle=1;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;" parent="1" vertex="1">
                    <mxGeometry x="50" y="35" width="700" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="arb_act" value="CONV ACT_R&lt;br/&gt;direct ingress&lt;br/&gt;highest read priority" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#0050ef;fontSize=14;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="80" y="180" width="260" height="90" as="geometry"/></mxCell>
                <mxCell id="arb_wgt" value="CONV WGT_R&lt;br/&gt;direct ingress&lt;br/&gt;second read priority" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#0050ef;fontSize=14;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="80" y="330" width="260" height="90" as="geometry"/></mxCell>
                <mxCell id="arb_l1r" value="L1Manager_R&lt;br/&gt;Requant / EWE / POOL / TNPS / UDMA" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="80" y="480" width="260" height="90" as="geometry"/></mxCell>
                <mxCell id="arb_l1w" value="L1Manager_W&lt;br/&gt;write ingress" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="80" y="660" width="260" height="75" as="geometry"/></mxCell>
                <mxCell id="arb_read" value="per-bank read arbiter&lt;br/&gt;1 ACT_R&lt;br/&gt;2 WGT_R&lt;br/&gt;3 L1Manager_R" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=15;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="520" y="260" width="260" height="180" as="geometry"/></mxCell>
                <mxCell id="arb_write" value="per-bank write slot&lt;br/&gt;L1Manager_W&lt;br/&gt;independent from read slot if dual-lane" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=15;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="520" y="610" width="260" height="140" as="geometry"/></mxCell>
                <mxCell id="arb_bank" value="selected bank tile&lt;br/&gt;16B read beat&lt;br/&gt;16B write beat&lt;br/&gt;per SRAM cycle" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;fontSize=15;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="980" y="385" width="260" height="190" as="geometry"/></mxCell>
                <mxCell id="arb_read_out" value="read data to requester" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="1350" y="300" width="220" height="70" as="geometry"/></mxCell>
                <mxCell id="arb_note" value="Direct CONV ingress bypasses L1_Manager arbitration, but all requests still converge at per-bank service. This keeps compute reads preferred without pretending the SRAM has unlimited read ports." style="rounded=1;arcSize=4;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#888888;fontSize=14;align=left;verticalAlign=middle;spacingLeft=14;" parent="1" vertex="1"><mxGeometry x="970" y="650" width="560" height="100" as="geometry"/></mxCell>
                <mxCell id="arb_e1" value="" style="endArrow=classic;html=1;rounded=0;strokeColor=#0050ef;strokeWidth=2;edgeStyle=orthogonalEdgeStyle;" parent="1" source="arb_act" target="arb_read" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell>
                <mxCell id="arb_e2" value="" style="endArrow=classic;html=1;rounded=0;strokeColor=#0050ef;strokeWidth=2;edgeStyle=orthogonalEdgeStyle;" parent="1" source="arb_wgt" target="arb_read" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell>
                <mxCell id="arb_e3" value="" style="endArrow=classic;html=1;rounded=0;strokeColor=#0050ef;strokeWidth=2;edgeStyle=orthogonalEdgeStyle;" parent="1" source="arb_l1r" target="arb_read" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell>
