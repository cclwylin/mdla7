                <mxCell id="title" value="MDLA7 — System Block Diagram (v0)" style="text;html=1;fontSize=24;fontStyle=1;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;" parent="1" vertex="1">
                    <mxGeometry x="40" y="20" width="900" height="44" as="geometry"/>
                </mxCell>
                <mxCell id="subtitle" value="Edge-TPU class NN HW accelerator — for SystemC modelling" style="text;html=1;fontSize=13;align=left;verticalAlign=middle;strokeColor=none;fillColor=none;fontColor=#666666;" parent="1" vertex="1">
                    <mxGeometry x="40" y="72" width="900" height="24" as="geometry"/>
                </mxCell>
                <mxCell id="sysparams" value="&lt;b&gt;System Parameters&lt;/b&gt;&lt;br/&gt;Clock: 1 GHz&amp;nbsp;&amp;nbsp;|&amp;nbsp;&amp;nbsp;CONV: 65,536 base 4×4 cells / 16 cluster (4 with FP)&lt;br/&gt;~1.05 M bit-mult / cycle (bit-level invariant, BitFusion-style)&lt;br/&gt;&lt;br/&gt;&lt;b&gt;Peak throughput @ 1 GHz&lt;/b&gt;&lt;br/&gt;INT8×4: 32,768 MAC&amp;nbsp;→&amp;nbsp;65.536 TOPS&amp;nbsp;&amp;nbsp;|&amp;nbsp;&amp;nbsp;INT8×8 (baseline): 16,384 MAC&amp;nbsp;→&amp;nbsp;32.768 TOPS&lt;br/&gt;INT16×16: 4,096 MAC&amp;nbsp;→&amp;nbsp;8.192 TOPS&lt;br/&gt;FP (FP8 E4M3 / FP16 E5M10 / BFP16 E8M7): 4,096 MAC&amp;nbsp;→&amp;nbsp;8.192 TFLOPS&lt;br/&gt;Accumulator: INT48&amp;nbsp;&amp;nbsp;|&amp;nbsp;&amp;nbsp;FP / INT: layer-serial only&lt;br/&gt;&lt;br/&gt;On-chip SRAM: 3 MB (L1Mesh 4x4 NoC)&amp;nbsp;&amp;nbsp;|&amp;nbsp;&amp;nbsp;Off-chip DRAM: 4 GB LPDDR6&lt;br/&gt;Engine sync: dependency tag (256 tags, in CmdEng tracker)&lt;br/&gt;Programming: 64 B descriptor, DRAM ring buffer + MMIO doorbell&lt;br/&gt;Model coverage: 61/61 target models (FP32 source via compiler)" style="rounded=1;arcSize=4;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#888888;align=left;verticalAlign=top;fontSize=12;spacingLeft=14;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="1480" y="20" width="820" height="240" as="geometry"/>
                </mxCell>
                <mxCell id="host" value="Host&lt;br/&gt;(RISC-V)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=16;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="320" width="220" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="cmdeng" value="Command Engine&lt;br/&gt;&lt;span style=&quot;font-size:12px;font-weight:normal;color:#444&quot;&gt;descriptor decode + dependency tracker → per-Engine config dispatch&lt;/span&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=16;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="320" y="320" width="1980" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="e_host_cmdeng" value="descriptor (1T)" style="endArrow=classic;html=1;rounded=0;strokeColor=#888888;strokeWidth=1.5;dashed=1;fontSize=11;fontColor=#444444;labelBackgroundColor=#ffffff;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="host" target="cmdeng" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="conv" value="CONV Engine&lt;br/&gt;&lt;span style=&quot;font-size:11px;font-weight:normal&quot;&gt;65,536 base 4×4 cells&lt;br/&gt;16 cluster (4 with FP)&lt;br/&gt;Bit-decomposable INT+FP&lt;br/&gt;&lt;i&gt;see page 2 for internals&lt;/i&gt;&lt;/span&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="378" y="480" width="280" height="160" as="geometry"/>
                </mxCell>
                <mxCell id="requant" value="Requant Engine&lt;br/&gt;&lt;span style=&quot;font-size:11px;font-weight:normal&quot;&gt;16 lanes (per-cluster)&lt;br/&gt;INT32 → INT8&lt;br/&gt;scale + shift + zp&lt;/span&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;" parent="1" vertex="1">
