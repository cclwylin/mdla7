                <mxCell id="l1n_plane_grid2" value="4x4" style="text;html=1;fontSize=30;fontStyle=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontColor=#0050ef;" parent="1" vertex="1"><mxGeometry x="905" y="305" width="110" height="50" as="geometry"/></mxCell>
                <mxCell id="l1n_plane_grid3" value="4x4" style="text;html=1;fontSize=30;fontStyle=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontColor=#8a6d3b;" parent="1" vertex="1"><mxGeometry x="615" y="570" width="110" height="50" as="geometry"/></mxCell>
                <mxCell id="l1n_plane_grid4" value="4x4" style="text;html=1;fontSize=30;fontStyle=1;align=center;verticalAlign=middle;strokeColor=none;fillColor=none;fontColor=#8a6d3b;" parent="1" vertex="1"><mxGeometry x="905" y="570" width="110" height="50" as="geometry"/></mxCell>
                <mxCell id="l1n_addr" value="bank = (addr &gt;&gt; 4) &amp;amp; 0xF&lt;br/&gt;macro = (addr &gt;&gt; 8) / 768&lt;br/&gt;row = (addr &gt;&gt; 8) % 768" style="rounded=1;arcSize=4;whiteSpace=wrap;html=1;fillColor=#eef7ff;strokeColor=#6c8ebf;fontSize=13;align=left;verticalAlign=middle;spacingLeft=12;" parent="1" vertex="1">
                    <mxGeometry x="1280" y="360" width="290" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="l1n_bw" value="Backend service target&lt;br/&gt;Read peak: 16 x 16B = 256B/SRAM-cycle&lt;br/&gt;Write peak: 16 x 16B = 256B/SRAM-cycle&lt;br/&gt;Direct CONV bypasses L1_Manager, not bank conflicts." style="rounded=1;arcSize=4;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#888888;fontSize=13;align=left;verticalAlign=middle;spacingLeft=12;" parent="1" vertex="1">
                    <mxGeometry x="1280" y="520" width="290" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="l1n_edge_note" value="Edge ports spread injection/ejection traffic across the 4x4 NoC. They reduce NoC-edge hot spots but do not increase per-bank SRAM service bandwidth." style="rounded=1;arcSize=4;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#888888;fontSize=13;align=left;verticalAlign=middle;spacingLeft=12;" parent="1" vertex="1">
                    <mxGeometry x="1280" y="690" width="290" height="115" as="geometry"/>
                </mxCell>
                <mxCell id="l1n_e_act" value="" style="endArrow=classic;html=1;rounded=0;strokeColor=#0050ef;strokeWidth=2;edgeStyle=orthogonalEdgeStyle;" parent="1" source="l1n_act" target="l1n_meshbox" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell>
                <mxCell id="l1n_e_wgt" value="" style="endArrow=classic;html=1;rounded=0;strokeColor=#0050ef;strokeWidth=2;edgeStyle=orthogonalEdgeStyle;" parent="1" source="l1n_wgt" target="l1n_meshbox" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell>
                <mxCell id="l1n_e_mgr" value="" style="endArrow=classic;html=1;rounded=0;strokeColor=#0050ef;strokeWidth=2;edgeStyle=orthogonalEdgeStyle;" parent="1" source="l1n_mgr" target="l1n_meshbox" edge="1"><mxGeometry relative="1" as="geometry"/></mxCell>
            </root>
        </mxGraphModel>
    </diagram>
