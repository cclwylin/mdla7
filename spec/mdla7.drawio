                    <mxGeometry x="50" y="30" width="900" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="l1n_note" value="16 banks; each bank = 16 x 768x16B macros = 192KB. Total = 16 x 192KB = 3MB. Four mesh edges each expose 4R + 4W ports; aggregate edge capacity = 16R + 16W." style="rounded=1;arcSize=4;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#888888;fontSize=13;align=left;verticalAlign=middle;spacingLeft=12;" parent="1" vertex="1">
