                    <mxGeometry x="390" y="280" width="105" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="l1n_edge_right" value="Right edge&lt;br/&gt;4R + 4W&lt;br/&gt;L1Mgr_R" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="1145" y="540" width="105" height="110" as="geometry"/>
                </mxCell>
                <mxCell id="l1n_edge_bottom" value="Bottom edge&lt;br/&gt;4R + 4W&lt;br/&gt;L1Mgr_W" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="850" y="690" width="220" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="l1n_plane_act" value="ACT_R plane&lt;br/&gt;4x4 mesh&lt;br/&gt;left-edge ingress" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#0050ef;strokeWidth=2;fontSize=13;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="560" y="255" width="220" height="150" as="geometry"/></mxCell>
                <mxCell id="l1n_plane_wgt" value="WGT_R plane&lt;br/&gt;4x4 mesh&lt;br/&gt;top-edge ingress" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#0050ef;strokeWidth=2;fontSize=13;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="850" y="255" width="220" height="150" as="geometry"/></mxCell>
                <mxCell id="l1n_plane_l1r" value="L1Manager_R plane&lt;br/&gt;4x4 mesh&lt;br/&gt;right-edge ingress" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontSize=13;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="560" y="520" width="220" height="150" as="geometry"/></mxCell>
                <mxCell id="l1n_plane_l1w" value="L1Manager_W plane&lt;br/&gt;4x4 mesh&lt;br/&gt;bottom-edge ingress" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontSize=13;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="850" y="520" width="220" height="150" as="geometry"/></mxCell>
                <mxCell id="l1n_shared_banks" value="shared 16-bank SRAM array&lt;br/&gt;B0..B15, 192KB each&lt;br/&gt;256 macros total&lt;br/&gt;capacity is 3MB, not 4x" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;strokeWidth=2;fontSize=14;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="675" y="740" width="280" height="105" as="geometry"/></mxCell>
