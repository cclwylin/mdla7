    <!-- BMM1 op -->
    <mxCell id="bmm1op" value="BMM1&lt;br/&gt;Q × K^T" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1E2761;strokeColor=#1E2761;fontFamily=Helvetica;fontSize=10;fontColor=#FFFFFF;" vertex="1" parent="1">
      <mxGeometry x="90" y="108" width="100" height="50" as="geometry"/>
