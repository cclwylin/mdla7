    <mxCell id="eng2" value="EWE + POOL" style="text;html=1;fontSize=9;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#9673a6;fontStyle=1;fontFamily=Helvetica;" vertex="1" parent="1">
