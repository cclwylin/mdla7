    <mxCell id="ea1" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#1E2761;strokeWidth=1.5;endArrow=block;endFill=1;" edge="1" source="bmm1op" target="smxop" parent="1">
      <mxGeometry relative="1" as="geometry"/>
