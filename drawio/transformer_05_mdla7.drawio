    <mxCell id="bmm2op" value="BMM2&lt;br/&gt;probs × V" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1E2761;strokeColor=#1E2761;fontFamily=Helvetica;fontSize=10;fontColor=#FFFFFF;" vertex="1" parent="1">
