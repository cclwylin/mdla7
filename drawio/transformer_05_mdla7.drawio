<mxGraphModel background="#FFFFFF" grid="0" pageWidth="760" pageHeight="480">
  <root>
    <mxCell id="0"/><mxCell id="1" parent="0"/>

    <mxCell id="ttl" value="Transformer → MDLA7 硬體對應" style="text;html=1;fontSize=15;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#1E2761;fontFamily=Helvetica;" vertex="1" parent="1">
      <mxGeometry x="180" y="10" width="400" height="28" as="geometry"/>
    </mxCell>

    <!-- Layer loop box -->
    <mxCell id="loop" value="" style="rounded=0;fillColor=#F7F9FF;strokeColor=#2D3E8A;strokeWidth=2;" vertex="1" parent="1">
      <mxGeometry x="30" y="50" width="700" height="380" as="geometry"/>
    </mxCell>
    <mxCell id="looplbl" value="for each layer  （Qwen3.5 = 24 層）" style="text;html=1;fontSize=10;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#2D3E8A;fontFamily=Helvetica;" vertex="1" parent="1">
      <mxGeometry x="40" y="53" width="280" height="18" as="geometry"/>
    </mxCell>

    <!-- ── Attention section ── -->
