    <mxCell id="ea2" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#1E2761;strokeWidth=1.5;endArrow=block;endFill=1;" edge="1" source="smxop" target="bmm2op" parent="1">
      <mxGeometry relative="1" as="geometry"/>
