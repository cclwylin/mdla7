    <!-- Engine labels for Attention -->
    <mxCell id="eng1" value="CONV Engine" style="text;html=1;fontSize=9;fillColor=#CADCFC;strokeColor=#6c8ebf;fontColor=#1E2761;fontStyle=1;fontFamily=Helvetica;" vertex="1" parent="1">
