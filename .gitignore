# macOS metadata sidecars (the 4T_OFFICE volume creates these on every file)
.DS_Store
._*

# Test models — too large for git; download separately per setup.sh / handoff.md
# Keep Hotspot slices because they are small regression/debug micro-patterns.
model/*
!model/Hotspot/
!model/Hotspot/*.tflite

# Compile artefacts
systemc/build/

# Per-model run outputs (regenerated by batch/run_model.py)
batch/output/

# Python caches
__pycache__/
*.py[cod]

# venvs (the canonical one lives at ~/.venvs/mdla7, not in-tree)
.venv/
venv/

# Editor / OS junk
*.swp
*~
.idea/
.vscode/

# drawio editor auto-backups
*.bkp
.$*

# sed -i.tmp leftovers
*.tmp
